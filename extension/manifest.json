{
  "manifest_version": 3,
  "name": "MAC.BID True Price",
  "version": "0.1.0",
  "description": "Estimate the actual MAC.BID total with fees and sales tax.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.mac.bid/*",
        "https://mac.bid/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "shared/fees.js",
        "shared/taxes.js",
        "shared/parser.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
